generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  CLASS_TEACHER
  HOD
}

enum AdmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OTPStatus {
  PENDING
  VERIFIED
  EXPIRED
}

enum FeeType {
  Tuition
  Transport
  Activity
  Outstanding
}

enum FeeStatus {
  PAID
  PENDING
  OVERDUE
}

enum AnnouncementCategory {
  Events
  Exams
  Holidays
  General
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  LEAVE_APPROVED
  LEAVE_REJECTED
  ADMISSION_APPROVED
  ADMISSION_REJECTED
  GENERAL
}

enum StudentStatus {
  PRE_APPLICANT
  APPLICANT
  STUDENT
  REJECTED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Student {
  id                    Int            @id @default(autoincrement())
  name                  String?        // Full name (set during enquiry)
  email                 String         @unique // Login email (set during sign-up)
  password              String         // Hashed password (set during sign-up)
  phone                 String?        // Phone (set during enquiry)
  parentName            String?        // Parent name (set during enquiry)
  parentEmail           String?        // Parent/Guardian email for notifications
  classEnrolled         String?        // Class (set during enquiry)
  rollNumber            String?        @unique // Official roll number (set on approval)
  officialEmail         String?        @unique // Official email (set on approval)
  admissionDate         DateTime?      // When admitted (set on approval)
  isActive              Boolean        @default(true)
  status                StudentStatus  @default(PRE_APPLICANT) // PRE_APPLICANT → APPLICANT → STUDENT/REJECTED
  enquiryNumber         String?        @unique // Unique enquiry reference (ENQ-2026-001)
  admissionId           Int?           // Link to Admission record
  admission             Admission?     @relation(fields: [admissionId], references: [id], onDelete: SetNull)
  documentsUploaded     String?        @db.LongText // JSON array of uploaded documents
  applicationFeePaid    Boolean        @default(false)
  applicationFeeAmount  Decimal?       @db.Decimal(10, 2)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime?      @updatedAt
  fees                  Fee[]
  leaveRequests         LeaveRequest[]
  notifications         Notification[]
  studentDocuments      StudentDocument[]
  feePaymentTransactions FeePaymentTransaction[]

  @@map("students")
}

model Staff {
  id                Int                 @id @default(autoincrement())
  name              String
  email             String              @unique
  password          String              // Hashed password
  role              Role                @default(CLASS_TEACHER)
  assignedClass     String?
  isActive          Boolean             @default(true)
  approvedBy        String?             // Email of HOD who approved
  approvedAt        DateTime?
  rejectionReason   String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime?           @updatedAt
  leaveRequests     LeaveRequest[]
  classAssignments  ClassAssignment[]
  staffLeaveBalance StaffLeaveBalance?

  @@map("staff")
}

model Admission {
  id              Int             @id @default(autoincrement())
  referenceNumber String          @unique
  studentName     String
  parentName      String
  email           String          // Parent/Guardian email for notifications
  phone           String
  classApplied    String
  status          AdmissionStatus @default(PENDING)
  submittedAt     DateTime        @default(now())
  approvedAt      DateTime?       // When HOD approved
  approvedBy      String?         // HOD email who approved
  rejectionReason String?         // Reason for rejection
  students        Student[]       // Reverse relation to Student

  @@map("admissions")
}

model Fee {
  id                      Int       @id @default(autoincrement())
  studentId               Int
  student                 Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term                    String
  dueDate                 DateTime
  amount                  Decimal   @db.Decimal(10, 2)
  paidAmount              Decimal   @default(0.00) @db.Decimal(10, 2)
  paidAt                  DateTime?
  paymentMethod           String?
  type                    FeeType
  status                  FeeStatus @default(PENDING)
  feePaymentTransactions  FeePaymentTransaction[]

  @@map("fees")
}

model Announcement {
  id          Int                  @id @default(autoincrement())
  title       String
  category    AnnouncementCategory
  description String               @db.Text
  author      String
  date        DateTime
  imageUrl    String?              @db.VarChar(1000)
  createdAt   DateTime             @default(now())

  @@map("announcements")
}

model LeaveRequest {
  id                Int                @id @default(autoincrement())
  // Either studentId OR staffId is set — not both
  studentId         Int?
  student           Student?           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  staffId           Int?
  staff             Staff?             @relation(fields: [staffId], references: [id], onDelete: Cascade)
  leaveType         String
  fromDate          DateTime
  toDate            DateTime
  reason            String             @db.Text
  status            LeaveRequestStatus @default(PENDING)
  rejectionReason   String?
  approvedBy        Int?
  approvedAt        DateTime?
  submittedAt       DateTime           @default(now())

  @@map("leave_requests")
}

model Notification {
  id        Int              @id @default(autoincrement())
  studentId Int
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@map("notifications")
}

model OTP {
  id        Int       @id @default(autoincrement())
  email     String
  code      String    @unique
  status    OTPStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@map("otps")
}

model EmailVerification {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@map("email_verifications")
}

model StaffSignupTemp {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  name          String
  password      String    // Hashed password
  role          Role      @default(CLASS_TEACHER)
  assignedClass String?
  expiresAt     DateTime  // OTP expires, so this signup data expires too
  createdAt     DateTime  @default(now())

  @@map("staff_signup_temp")
}

model PaymentOrder {
  id                Int       @id @default(autoincrement())
  feeId             Int
  studentId         Int
  amountPaise       Int       // Amount in paise (1 rupee = 100 paise)
  currency          String    @default("INR")
  razorpayOrderId   String    @unique
  status            String    @default("CREATED") // CREATED, PAID, FAILED
  receipt           String?   @db.VarChar(500)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("payment_orders")
}

model PaymentTransaction {
  id                  Int       @id @default(autoincrement())
  razorpayOrderId     String    @unique
  razorpayPaymentId   String
  razorpaySignature   String
  rawResponse         String?   @db.LongText // JSON response from Razorpay
  createdAt           DateTime  @default(now())

  @@map("payment_transactions")
}

model FeeReceipt {
  id                Int       @id @default(autoincrement())
  razorpayOrderId   String    @unique
  receiptNumber     String?   @unique
  issuedAt          DateTime
  createdAt         DateTime  @default(now())

  @@map("fee_receipts")
}

model AuditLog {
  id           Int       @id @default(autoincrement())
  action       String
  entityType   String
  entityId     Int
  userId       Int?
  userRole     Role
  oldValue     String?   @db.LongText
  newValue     String?   @db.LongText
  details      String?   @db.LongText
  timestamp    DateTime  @default(now())

  @@map("audit_logs")
  @@index([entityType, entityId])
  @@index([userId])
  @@index([timestamp])
}

model StudentDocument {
  id               Int       @id @default(autoincrement())
  studentId        Int
  student          Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  documentType     String
  fileName         String
  fileUrl          String    @db.VarChar(500)
  fileSize         Int?
  uploadedAt       DateTime  @default(now())
  status           String    @default("PENDING") // PENDING, VERIFIED, REJECTED
  verifiedBy       Int?
  verifiedAt       DateTime?
  rejectionReason  String?

  @@map("student_documents")
  @@index([studentId])
  @@index([status])
}

model FeePaymentTransaction {
  id               Int       @id @default(autoincrement())
  feeId            Int
  fee              Fee       @relation(fields: [feeId], references: [id], onDelete: Cascade)
  studentId        Int
  student          Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount           Decimal   @db.Decimal(10, 2)
  paymentMethod    String    // ONLINE, CASH, CHECK, BANK_TRANSFER
  transactionId    String?
  paymentDate      DateTime  @default(now())
  razorpayOrderId  String?
  razorpayPaymentId String?
  status           String    @default("SUCCESS") // SUCCESS, FAILED, PENDING
  notes            String?

  @@map("fee_payment_transactions")
  @@index([feeId])
  @@index([studentId])
  @@index([paymentDate])
}

model PaymentWebhookLog {
  id               Int       @id @default(autoincrement())
  event            String
  razorpayOrderId  String?
  razorpayPaymentId String?
  payload          String    @db.LongText
  status           String    @default("PENDING") // PROCESSED, FAILED, PENDING
  errorMessage     String?
  processedAt      DateTime?
  receivedAt       DateTime  @default(now())

  @@map("payment_webhook_logs")
  @@index([razorpayOrderId])
  @@index([event])
  @@index([receivedAt])
}

model EmailLog {
  id                Int       @id @default(autoincrement())
  recipientEmail    String
  subject           String
  emailType         String
  relatedEntityType String?
  relatedEntityId   Int?
  status            String    @default("SENT") // SENT, FAILED, BOUNCED
  errorMessage      String?
  sentAt            DateTime  @default(now())

  @@map("email_logs")
  @@index([recipientEmail])
  @@index([emailType])
  @@index([sentAt])
}

model ClassAssignment {
  id            Int       @id @default(autoincrement())
  staffId       Int
  staff         Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  classEnrolled String
  assignedAt    DateTime  @default(now())
  unassignedAt  DateTime?
  reason        String?

  @@map("class_assignments")
  @@index([staffId])
  @@index([classEnrolled])
  @@index([assignedAt])
}

model StaffLeaveBalance {
  id              Int       @id @default(autoincrement())
  staffId         Int       @unique
  staff           Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  year            Int
  totalYearlyLeave Int      @default(20)
  usedLeave       Int       @default(0)
  remainingLeave  Int       @default(20)
  monthlyUsed     Int       @default(0)
  lastUpdatedAt   DateTime  @default(now()) @updatedAt

  @@map("staff_leave_balance")
  @@unique([staffId, year])
  @@index([year])
}
