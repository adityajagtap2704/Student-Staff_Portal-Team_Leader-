generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  CLASS_TEACHER
  HOD
}

enum AdmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OTPStatus {
  PENDING
  VERIFIED
  EXPIRED
}

enum FeeType {
  Tuition
  Transport
  Activity
}

enum FeeStatus {
  PAID
  PENDING
  OVERDUE
}

enum AnnouncementCategory {
  Events
  Exams
  Holidays
  General
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  LEAVE_APPROVED
  LEAVE_REJECTED
  ADMISSION_APPROVED
  ADMISSION_REJECTED
  GENERAL
}

enum StudentStatus {
  PRE_APPLICANT
  APPLICANT
  STUDENT
  REJECTED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Student {
  id                    Int            @id @default(autoincrement())
  name                  String?        // Full name (set during enquiry)
  email                 String         @unique // Login email (set during sign-up)
  password              String         // Hashed password (set during sign-up)
  phone                 String?        // Phone (set during enquiry)
  parentName            String?        // Parent name (set during enquiry)
  parentEmail           String?        // Parent/Guardian email for notifications
  classEnrolled         String?        // Class (set during enquiry)
  rollNumber            String?        @unique // Official roll number (set on approval)
  officialEmail         String?        @unique // Official email (set on approval)
  admissionDate         DateTime?      // When admitted (set on approval)
  isActive              Boolean        @default(true)
  status                StudentStatus  @default(PRE_APPLICANT) // PRE_APPLICANT → APPLICANT → STUDENT/REJECTED
  enquiryNumber         String?        @unique // Unique enquiry reference (ENQ-2026-001)
  admissionId           Int?           // Link to Admission record
  admission             Admission?     @relation(fields: [admissionId], references: [id], onDelete: SetNull)
  documentsUploaded     String?        @db.LongText // JSON array of uploaded documents
  applicationFeePaid    Boolean        @default(false)
  applicationFeeAmount  Decimal?       @db.Decimal(10, 2)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  fees                  Fee[]
  leaveRequests         LeaveRequest[]
  notifications         Notification[]

  @@map("students")
}

model Staff {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  password      String         // Hashed password
  role          Role           @default(CLASS_TEACHER)
  assignedClass String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  leaveRequests LeaveRequest[]

  @@map("staff")
}

model Admission {
  id              Int             @id @default(autoincrement())
  referenceNumber String          @unique
  studentName     String
  parentName      String
  email           String          // Parent/Guardian email for notifications
  phone           String
  classApplied    String
  status          AdmissionStatus @default(PENDING)
  submittedAt     DateTime        @default(now())
  approvedAt      DateTime?       // When HOD approved
  approvedBy      String?         // HOD email who approved
  rejectionReason String?         // Reason for rejection
  students        Student[]       // Reverse relation to Student

  @@map("admissions")
}

model Fee {
  id         Int       @id @default(autoincrement())
  studentId  Int
  student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term       String
  dueDate    DateTime
  amount     Decimal   @db.Decimal(10, 2)
  paidAmount Decimal   @default(0.00) @db.Decimal(10, 2)
  type       FeeType
  status     FeeStatus @default(PENDING)

  @@map("fees")
}

model Announcement {
  id          Int                  @id @default(autoincrement())
  title       String
  category    AnnouncementCategory
  description String               @db.Text
  author      String
  date        DateTime
  imageUrl    String?              @db.VarChar(1000)
  createdAt   DateTime             @default(now())

  @@map("announcements")
}

model LeaveRequest {
  id          Int                @id @default(autoincrement())
  // Either studentId OR staffId is set — not both
  studentId   Int?
  student     Student?           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  staffId     Int?
  staff       Staff?             @relation(fields: [staffId], references: [id], onDelete: Cascade)
  leaveType   String
  fromDate    DateTime
  toDate      DateTime
  reason      String             @db.Text
  status      LeaveRequestStatus @default(PENDING)
  submittedAt DateTime           @default(now())

  @@map("leave_requests")
}

model Notification {
  id        Int              @id @default(autoincrement())
  studentId Int
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@map("notifications")
}

model OTP {
  id        Int       @id @default(autoincrement())
  email     String
  code      String    @unique
  status    OTPStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@map("otps")
}

model EmailVerification {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@map("email_verifications")
}
